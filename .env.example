# App
ENV=development
PROJECT_NAME=RealEstateSocial
LIVE_DOMAIN=https://example.com
LOG_LEVEL=info

# API
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
SESSION_COOKIE_NAME=res_session
CSRF_COOKIE_NAME=res_csrf
SESSION_MAX_AGE_SECONDS=86400
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/realestate
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://redis:6379/0

# Object storage (MinIO for local development)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_NAME=realestate-media
S3_PUBLIC_URL=http://localhost:9000/realestate-media
S3_USE_SSL=false
S3_SIGNATURE_VERSION=s3v4

# Encryption
# Valid 32-byte url-safe base64 Fernet key (dev/CI only — generate a new one for production)
OAUTH_ENCRYPTION_KEY=E14MeR_CCL3_Z1DPIjLdwyKaesR31uBoRFNFregVs-A=

# OAuth credentials — required for live multi-account publishing (no mocks)
# Instagram API with Instagram Login (Business/Creator)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/social-accounts/instagram/callback

# X API v2 (OAuth 2.0 PKCE)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/api/v1/social-accounts/x/callback

# Feature flags — live publishing only
LIVE_INSTAGRAM_PUBLISHING=true
LIVE_X_PUBLISHING=true
AI_CONTENT_ASSISTANCE=false
VIDEO_PUBLISHING=false
SCHEDULING=false
ANALYTICS_COLLECTION=false
WEBHOOKS=false
AUTO_PUBLISH_WITHOUT_REVIEW=false
WATERMARKING=false

# Email / notifications (SMTP optional; for MVP password reset uses token shown in logs if no SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# Error monitoring (DSN optional)
SENTRY_DSN=
