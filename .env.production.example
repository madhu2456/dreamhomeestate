# Copy to server as /opt/dreamhomeestate/.env (deploy.sh generates this automatically)
# Domain: dreamhomeestate.madhudadi.in

ENV=production
PROJECT_NAME=DreamHomeEstate
LIVE_DOMAIN=https://dreamhomeestate.madhudadi.in
LOG_LEVEL=info

SECRET_KEY=replace-with-openssl-rand-hex-32
SESSION_COOKIE_NAME=dhe_session
SESSION_MAX_AGE_SECONDS=86400
CORS_ALLOWED_ORIGINS=https://dreamhomeestate.madhudadi.in

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
POSTGRES_DB=realestate
DATABASE_URL=postgresql+asyncpg://postgres:replace-me@postgres:5432/realestate
DATABASE_POOL_SIZE=10

REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=replace-me
S3_REGION=us-east-1
S3_BUCKET_NAME=realestate-media
S3_PUBLIC_URL=https://dreamhomeestate.madhudadi.in/media
S3_USE_SSL=false
S3_SIGNATURE_VERSION=s3v4

OAUTH_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://dreamhomeestate.madhudadi.in/api/v1/social-accounts/instagram/callback

X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=https://dreamhomeestate.madhudadi.in/api/v1/social-accounts/x/callback

LIVE_INSTAGRAM_PUBLISHING=true
LIVE_X_PUBLISHING=true

APP_PORT=3010
MINIO_PORT=9010
NEXT_PUBLIC_API_URL=
API_INTERNAL_URL=http://api:8000
